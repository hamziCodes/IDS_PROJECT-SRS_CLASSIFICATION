{
  "builds": [
    {
      "src": "vertex_app/backend/index.py",
      "use": "@vercel/python"
    }
  ],
  "functions": {
    "vertex_app/backend/index.py": {
      "includeFiles": "{PROJECT/**,trained_models/**}"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vertex_app/backend/index.py"
    }
  ]
}