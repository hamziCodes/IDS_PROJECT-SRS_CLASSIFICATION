{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "env": {
    "PYTHON_VERSION": "3.11"
  },
"builds": [
    {
      "src": "vertex_app/backend/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "{PROJECT/**,trained_models/**,pipeline_common.py}"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vertex_app/backend/index.py"
    }
  ]
}