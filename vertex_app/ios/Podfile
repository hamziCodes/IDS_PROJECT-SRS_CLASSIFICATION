platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', 'Debug' => :debug, 'Release' => :release

def flutter_root
  generated_xcconfig = File.join(__dir__, 'Flutter', 'Generated.xcconfig')
  unless File.exist?(generated_xcconfig)
    raise "#{generated_xcconfig} must exist. Run 'flutter pub get' first."
  end
  content = File.read(generated_xcconfig)
  match = content.match(/FLUTTER_ROOT\=(.*)/)
  return match[1].strip if match
  raise 'FLUTTER_ROOT not found in Generated.xcconfig'
end

require File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  install_all_flutter_pods(File.dirname(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end
