platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', 'Debug' => :debug, 'Release' => :release

def flutter_root_from_generated
  generated_xcconfig = File.join(__dir__, 'Flutter', 'Generated.xcconfig')
  return nil unless File.exist?(generated_xcconfig)
  content = File.read(generated_xcconfig)
  match = content.match(/FLUTTER_ROOT\=(.*)/)
  return nil unless match
  # Normalize Windows paths (e.g. D:\Foo\flutter) to Unix style where possible
  path = match[1].strip.gsub('\\', '/')
  path
end

flutter_root = ENV['FLUTTER_ROOT']
flutter_root = flutter_root_from_generated if flutter_root.nil? || flutter_root.empty?
raise 'FLUTTER_ROOT not found. Ensure Flutter is installed on the runner.' if flutter_root.nil? || flutter_root.empty?

require File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')

target 'Runner' do
  # Remove use_frameworks! and use_modular_headers! to allow Flutter's
  # pod helper to integrate the engine/frameworks correctly on CI.
  # (Using frameworks can interfere with the Flutter module being
  # visible to Swift-based plugin pods.)
  flutter_install_all_ios_pods(File.dirname(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end
